rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(parentId) {
      return isAuth() && request.auth.uid == parentId;
    }
    function entitlementDoc(parentId) {
      return exists(/databases/$(database)/documents/accountEntitlements/$(parentId))
        ? get(/databases/$(database)/documents/accountEntitlements/$(parentId)).data
        : null;
    }
    function entitlementPlanId(parentId) {
      let entitlement = entitlementDoc(parentId);
      return entitlement != null && entitlement.plan_id is string
        ? entitlement.plan_id
        : "free";
    }
    function hasLockdownEntitlement(parentId) {
      let entitlement = entitlementDoc(parentId);
      return entitlementPlanId(parentId) == "lockdown" ||
        (
          entitlement != null &&
          entitlement.feature_overrides is map &&
          (
            entitlement.feature_overrides.can_use_lockdown_extension == true ||
            entitlement.feature_overrides.can_use_lockdown_kiosk == true
          )
        );
    }
    function studentExists(studentId) {
      return exists(/databases/$(database)/documents/students/$(studentId));
    }
    function subjectExists(subjectId) {
      return exists(/databases/$(database)/documents/subjects/$(subjectId));
    }
    function timerSubjectIsAssigned(studentId, subjectId) {
      let subject = subjectExists(subjectId)
        ? get(/databases/$(database)/documents/subjects/$(subjectId)).data
        : null;
      return subject != null && (
        (subject.student_ids is list && studentId in subject.student_ids) ||
        subject.student_id == studentId
      );
    }
    function validTimerTimerSessionData(data) {
      return data.student_id is string &&
        data.subject_id is string &&
        data.parent_id is string &&
        data.block_index is int &&
        data.start_time is int &&
        data.duration_ms is int &&
        data.duration_minutes is int &&
        data.target_end_time is int &&
        data.initial_duration_ms is int &&
        data.remaining_time is int &&
        data.is_running is bool &&
        data.saved_at is int;
    }

    // Students: portal resolves student records by slug, which requires query/list access
    match /students/{studentId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isOwner(resource.data.parent_id);
    }

    // Subjects: parents own their records; students need read access for the portal
    match /subjects/{subjectId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isOwner(resource.data.parent_id);
    }

    // Submissions: students write (portal is unauthenticated), parents read their own
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuth();
    }

    // Timer sessions: portal needs unauthenticated cross-device persistence
    match /timerSessions/{timerSessionId} {
      allow get: if studentExists(resource.data.student_id) &&
        timerSubjectIsAssigned(resource.data.student_id, resource.data.subject_id);
      allow list: if false;
      allow create, update: if studentExists(request.resource.data.student_id) &&
        timerSubjectIsAssigned(request.resource.data.student_id, request.resource.data.subject_id) &&
        validTimerTimerSessionData(request.resource.data);
      allow delete: if studentExists(resource.data.student_id) &&
        timerSubjectIsAssigned(resource.data.student_id, resource.data.subject_id);
    }

    // Weekly reports: parent-scoped only
    match /weeklyReports/{reportId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.parent_id;
      allow create: if isOwner(request.resource.data.parent_id);
    }

    // Parent profiles: owner only
    match /parents/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Account entitlements: server-owned billing and plan state
    match /accountEntitlements/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Lockdown PoC policies: public read for Phase 4 extension polling, owner-only writes
    match /lockdownPolicies/{policyId} {
      allow get: if true;
      allow list, delete: if isAuth() && request.auth.uid == policyId;
      allow create: if isAuth() &&
        request.auth.uid == policyId &&
        request.resource.data.parent_id == request.auth.uid &&
        hasLockdownEntitlement(request.auth.uid);
      allow update: if isAuth() &&
        request.auth.uid == policyId &&
        resource.data.parent_id == request.auth.uid &&
        request.resource.data.parent_id == request.auth.uid &&
        hasLockdownEntitlement(request.auth.uid);
    }

    // Daily logs remain parent-authenticated until a narrower trusted path exists.
    match /dailyLogs/{logId} {
      allow read, write: if isAuth();
    }

    // Deny everything else by default so specific collection matches stay authoritative.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
