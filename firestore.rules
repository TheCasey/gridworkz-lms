rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Allow the Student Portal to find a student by their slug
    match /students/{studentId} {
      allow read: if true; 
      allow write: if request.auth != null;
    }

    // 2. Allow the Student Portal to see subjects and make submissions
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if true; // Temporary so students can click 'Done'
    }

    match /submissions/{submissionId} {
      allow read, write: if true;
    }

    // 3. Keep Parent documents private to the logged-in Parent
    match /parents/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. Default for everything else (Reports, Logs)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}